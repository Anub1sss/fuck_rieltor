# Django
SECRET_KEY=your-secret-key-change-me
DEBUG=0
ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1

# Database
DB_HOST=db
DB_NAME=rieltor_db
DB_USER=postgres
DB_PASSWORD=postgres

# Redis / Celery
REDIS_HOST=redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS — домен вашего score-service
CORS_ORIGINS=http://localhost:3002,http://your-domain.com:3002

# Score-service — URL бэкенда (как его видит браузер пользователя)
SCORE_API_URL=http://your-domain.com:8000/api
